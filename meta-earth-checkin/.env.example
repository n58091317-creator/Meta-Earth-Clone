# Copy this to .env for local dev, or add these as Replit Secrets

# Your Meta Earth wallet mnemonic phrase (12 or 24 words)
MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# For multiple wallets, use numbered variables:
# MNEMONIC_1=word1 word2 ... word12
# MNEMONIC_2=word1 word2 ... word12

# Network: mainnet or testnet
NETWORK=mainnet

# Cron schedule (default: 08:00 UTC daily)
# See https://crontab.guru for help
CRON_SCHEDULE=0 8 * * *

# Set to true to run check-in immediately when the bot starts
RUN_ON_START=true

# Set to true for verbose SDK logs
DEBUG=false
