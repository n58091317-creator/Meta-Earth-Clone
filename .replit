modules = ["nodejs-20", "go-1.21", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["pnpm", "--filter", "@workspace/dashboard", "run", "start"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/dashboard run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Meta Earth Check-in Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Meta Earth Check-in Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/meta-earth-checkin run dev"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'pnpm --filter @workspace/dashboard run build && pnpm --filter @workspace/dashboard run start'"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[userenv]

[userenv.shared]
NETWORK = "mainnet"
RUN_ON_START = "true"
VITE_FIREBASE_API_KEY = "AIzaSyD8AxG6rczvtF5N1FjerzwitaSLR00Pgys"
VITE_FIREBASE_AUTH_DOMAIN = "meta-earth-dashboard.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "meta-earth-dashboard"
VITE_FIREBASE_STORAGE_BUCKET = "meta-earth-dashboard.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "458596550832"
VITE_FIREBASE_APP_ID = "1:458596550832:web:858da43458cbf77aa31375"
FIREBASE_PROJECT_ID = "meta-earth-dashboard"

[nix]
channel = "stable-25_05"
packages = ["python313Packages.open-interpreter"]
