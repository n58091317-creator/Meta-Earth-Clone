{
  "name": "meta-earth-js-sdk",
  "version": "1.0.0",
  "description": "A TypeScript SDK template supporting both browser and Node.js environments",
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:demo": "cd examples/react-demo && pnpm run build",
    "dev": "vite",
    "demo": "pnpm run build && cd examples/react-demo && pnpm i && pnpm run dev",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sdk",
    "typescript",
    "vite",
    "browser",
    "nodejs",
    "universal"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cosmjs/amino": "^0.31.3",
    "@cosmjs/encoding": "^0.33.0",
    "@cosmjs/launchpad": "^0.27.1",
    "@cosmjs/proto-signing": "^0.31.3",
    "@cosmjs/stargate": "^0.31.3",
    "@keplr-wallet/types": "^0.11.3",
    "axios": "0.21.4",
    "bech32": "1.1.3",
    "bignumber.js": "^9.3.1",
    "bip32": "2.0.6",
    "bip39": "2.6.0",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "long": "^5.3.2",
    "protobufjs": "^7.5.4",
    "secp256k1": "3.8.0",
    "uint8arrays": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^18.15.3",
    "@vitest/ui": "^4.0.10",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.5",
    "terser": "^5.44.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^4.0.10"
  }
}
